# ============================================================================
# my-service — environment variables (template)
# ============================================================================
# Copie para `.env` (ou use em docker-compose). Nunca commite o `.env`.

# ---------- Server ----------
PORT=8080
GIN_MODE=debug                  # debug | release | test
LOG_LEVEL=info                  # debug | info | warn | error

# ---------- Database ----------
DATABASE_URL=postgres://app:app@postgres:5432/app?sslmode=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# ---------- Auth ----------
JWT_SECRET=change-me-in-production
JWT_TTL=24h
JWT_ISSUER=my-service

# ---------- Observability ----------
METRICS_PATH=/metrics
OTEL_EXPORTER_OTLP_ENDPOINT=    # ex.: otel-collector:4318 (vazio = tracing desabilitado)
OTEL_SERVICE_NAME=my-service
APP_VERSION=dev                 # injetado no build via -ldflags
APP_COMMIT=unknown              # injetado no build via -ldflags

# ---------- External services ----------
# (adicione os seus aqui; ex.: SMTP_URL, REDIS_URL, etc.)
# SMTP_URL=smtp://user:pass@smtp.example.com:587
# REDIS_URL=redis://redis:6379/0
